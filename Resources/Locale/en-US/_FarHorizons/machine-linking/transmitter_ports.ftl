# Holographic Generator

signal-port-name-holographic-generator-connection-status = Field Status
signal-port-description-holographic-generator-connection-status = This port is invoked with HIGH when the field forms and LOW when the field fizzles out.

signal-port-name-holographic-generator-field-connected = Field Connected
signal-port-description-holographic-generator-field-connected = This port is invoked whenever the field forms.

signal-port-name-holographic-generator-field-disconnected = Field Disconnected
signal-port-description-holographic-generator-field-disconnected = This port is invoked whenever the field fizzles out.

# Nuclear Reactor

signal-port-name-nuclear-reactor-control-rods-avg = Control Rods Average
signal-port-description-nuclear-reactor-control-rods-avg = Circuit port with the reactor's average control rod insertion in percent as an integer.

signal-port-name-nuclear-reactor-casing-temp = Casing Temperature
signal-port-description-nuclear-reactor-casing-temp = Circuit port with the reactor's casing temperature in degrees Kelvin as an integer.

signal-port-name-nuclear-reactor-thermal-power = Thermal Power Output
signal-port-description-nuclear-reactor-thermal-power = Circuit port with the reactor's thermal power output in Watts as an integer.

signal-port-name-nuclear-reactor-data-sender = Nuclear Reactor
signal-port-description-nuclear-reactor-data-sender = Sending info about a nuclear reactor to a monitor.

# Gas Turbine

signal-port-name-gas-turbine-speed = Turbine Speed
signal-port-description-gas-turbine-speed = Circuit port with the turbine's current speed in RPM as an integer.

signal-port-name-gas-turbine-speed-high = High Speed
signal-port-description-gas-turbine-speed-high = Invoked with HIGH when speed is higher than optimal.

signal-port-name-gas-turbine-speed-low = Low Speed
signal-port-description-gas-turbine-speed-low = Invoked with HEIGH when speed is lower than optimal.

signal-port-name-gas-turbine-generated = Power Generated
signal-port-description-gas-turbine-generated = Circuit port with the turbine's current HV power generation in Watts as an integer.

signal-port-name-gas-turbine-supply = Power Supplied
signal-port-description-gas-turbine-supply = Circuit port with the turbine's current HV power actually being used in Watts as an integer.

signal-port-name-gas-turbine-data-sender = Gas Turbine
signal-port-description-gas-turbine-data-sender = Sending info about a gas turbine to a monitor.
