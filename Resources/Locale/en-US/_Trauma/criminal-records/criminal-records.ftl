criminal-records-status-brutalize = Brutalize

criminal-records-console-brutalize-reason = Brutalize Reason

criminal-records-console-brutalize = {$officer} marked {$name} ({$job}) for a beating because of: {$reason}
criminal-records-console-not-brutalize = {$officer} marked {$name} ({$job}) as sufficiently beaten.

criminal-records-status-demote = Demote

criminal-records-console-demote-reason = Demote Reason

criminal-records-console-demote = {$officer} marked {$name} ({$job}) for demotion because of: {$reason}
criminal-records-console-not-demote = {$officer} marked {$name} ({$job}) is no longer marked for demotion.
