<circuits:IntPickerWindow xmlns="https://spacestation14.io"
        xmlns:circuits="using:Content.Trauma.Client.Circuits.UI"
        MinSize="300 150"
        Title="Circuit Constant: Integer">
    <BoxContainer Orientation="Vertical" Align="Center">
        <BoxContainer Orientation="Horizontal" Align="Center" Margin="8">
            <Label Text="Value" Margin="8"/>
            <LineEdit Name="ValueEdit" Text="0" PlaceHolder="Integer (whole number) value" MinWidth="60"/>
        </BoxContainer>
        <Button Name="CreateButton" Text="Create" MaxWidth="80"/>
    </BoxContainer>
</circuits:IntPickerWindow>
