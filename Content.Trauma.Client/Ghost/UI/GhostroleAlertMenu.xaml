<controls:FancyWindow xmlns="https://spacestation14.io"
        xmlns:controls="using:Content.Client.UserInterface.Controls"
        Title="{Loc 'ghost-role-spawned'}">
    <BoxContainer Orientation="Vertical" Margin="5">
        <Label Text="{Loc 'ghost-role-spawned-text'}" VerticalExpand="True"/>
        <BoxContainer Orientation="Horizontal" Align="Center" Margin="0 20 0 0">
            <Button Name="ConfirmButton" Text="{Loc 'ghost-role-confirm'}"/>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
